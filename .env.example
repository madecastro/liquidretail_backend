MONGODB_URI=your-mongodb-connection-string
OPENAI_API_KEY=your-openai-key
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
SHOPIFY_API_KEY=your_key
SHOPIFY_API_SECRET=your_secret
SHOPIFY_ACCESS_TOKEN=your_access_token
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com
RUN_WORKER=true

# Gemini (detect pipeline, extended-ratio candidates)
# AI Studio key, 39 chars, prefix "AIza..." — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-ai-studio-key
# Optional: pin a specific model. If unset, ListModels picks the first image-capable one.
# e.g. gemini-2.5-flash-image, gemini-3-pro-image-preview, gemini-3.1-flash-image-preview
GEMINI_IMAGE_MODEL=

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://liquidretail-backend.onrender.com/auth/google/callback
SESSION_SECRET=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-a-long-random-string
