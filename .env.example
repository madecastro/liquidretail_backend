MONGODB_URI=your-mongodb-connection-string
OPENAI_API_KEY=your-openai-key
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
SHOPIFY_API_KEY=your_key
SHOPIFY_API_SECRET=your_secret
SHOPIFY_ACCESS_TOKEN=your_access_token
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com
RUN_WORKER=true
# How many DetectRuns process concurrently in this worker process.
# Default 2 (safe on Render free tier 512MB). Bump up on paid plans:
#   Standard 2GB → 8-10
#   Pro      4GB → 20-30
#   Pro Plus 8GB → 50+
# Pipeline is mostly I/O so memory is the real ceiling. Cap is 100.
# Mongoose pool sizes itself to 3× concurrency (capped at 200) to
# avoid head-of-line blocking at high concurrency.
WORKER_CONCURRENCY=2

# Gemini (detect pipeline, extended-ratio candidates + grounded product search)
# AI Studio key, 39 chars, prefix "AIza..." — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-ai-studio-key
# Optional: pin a specific model for image generation. If unset, ListModels picks
# the first image-capable one. e.g. gemini-2.5-flash-image, gemini-3.1-flash-image-preview
GEMINI_IMAGE_MODEL=
# Model used for grounded product-match search (text-based). Default gemini-2.5-flash.
GEMINI_SEARCH_MODEL=

# SerpAPI — Google Lens visual product matching (detect pipeline, product-match stage)
# Get from https://serpapi.com/dashboard
SERPAPI_API_KEY=your-serpapi-key
# Optional: country biasing for Google Lens results. Default "us".
SERPAPI_COUNTRY=

# Brandfetch — brand-kit lookup (logo, colors, fonts) by domain. Used by
# brand enrichment as the primary visual-identity source; falls back to
# homepage scraping (apple-touch-icon + Google Fonts links + meta theme-color)
# when missing or 404. Get from https://developers.brandfetch.com/
BRANDFETCH_API_KEY=your-brandfetch-key

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://liquidretail-backend.onrender.com/auth/google/callback
SESSION_SECRET=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-a-long-random-string

# Meta / Instagram OAuth (Phase A — Connect Instagram on brand page).
# Register a Business app at https://developers.facebook.com/apps/, add
# the Facebook Login product, set Valid OAuth Redirect URIs to the
# callback URL below, and request these permissions during App Review:
# instagram_basic, pages_show_list, pages_read_engagement,
# business_management, catalog_management.
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=https://liquidretail-backend.onrender.com/api/integrations/instagram/callback
# Optional: pin a specific Graph API version. Default v19.0.
META_API_VERSION=

# AES-256 key for encrypting third-party access tokens at rest. Must be
# 32 bytes base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INTEGRATION_ENCRYPTION_KEY=base64-32-bytes-here

# Meta webhook verify token (V3 #1). Arbitrary string you also paste
# into the Meta App Dashboard when setting up the webhook subscription;
# Meta echoes it back during the GET verification handshake.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
META_WEBHOOK_VERIFY_TOKEN=any-long-random-string

# Meta Ads OAuth callback (Ad Platforms Phase A). Same Meta App as the
# IG integration above, just a separate Valid OAuth Redirect URI for
# ads scopes (ads_read, ads_management, business_management). Add this
# URL to the same Meta App's Facebook Login → Valid OAuth Redirect URIs.
META_ADS_REDIRECT_URI=https://liquidretail-backend.onrender.com/api/integrations/meta-ads/callback

# Google Ads OAuth (Ad Platforms Phase A.2).
#
# Two options for the OAuth client:
#   A) Reuse the user-signin Google client (GOOGLE_CLIENT_ID/SECRET above) —
#      just register the redirect URI below on that client. Convenient
#      when the same Google Cloud project owns both flows.
#   B) Use a DIFFERENT Google Cloud project — typically the one whose
#      developer-token application has been approved + live for Google
#      Ads. Set GOOGLE_ADS_CLIENT_ID + GOOGLE_ADS_CLIENT_SECRET; they
#      take precedence over the shared GOOGLE_CLIENT_ID/SECRET above.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REDIRECT_URI=https://liquidretail-backend.onrender.com/api/integrations/google-ads/callback

# Google Ads Developer Token. Server-wide secret required by every
# Google Ads API call. Apply at https://ads.google.com/aw/apicenter
# (test access is granted instantly; production requires Google review).
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token

# Optional: pin the Google Ads API version used by REST calls. Default v17.
GOOGLE_ADS_API_VERSION=
