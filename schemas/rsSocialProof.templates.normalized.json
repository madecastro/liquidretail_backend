      },
      "style_bindings": {
        "stat_card_bg":         { "source_priority": ["brand.primary_color"],   "default": "#0B1020" },
        "stat_card_text":       { "default": "auto-from-brightness" },
        "metric_accent_color":  { "source_priority": ["brand.accent_color"],    "default": "#7A35E8" },
        "headline_text_color":  { "source_priority": ["brand.primary_color"],   "default": "#0B1020" },
        "rating_star_color":    { "default": "#FFD400" },
        "trust_footer_bg":      { "source_priority": ["brand.secondary_color"], "default": "#F3F4F6" },
        "trust_footer_text":    { "default": "auto-from-brightness" },
        "cta_button_bg":        { "source_priority": ["brand.accent_color", "brand.primary_color"], "default": "#000000" },
        "cta_button_text":      { "default": "auto-from-brightness" },
        "font_family_headline": { "source_priority": ["brand.font_family"], "default": "system-ui" },
        "font_family_body":     { "source_priority": ["brand.font_family"], "default": "system-ui" }
      },
      "validation": {
        "required_all_of": ["copy.headline", "cta.text"],
        "required_any_of": [["performance.metrics"]],
        "minimum_counts": { "performance.metrics": 2 }
      }
    },
    {
      "template_id": "testimonial_overlay",
      "version": "1.0.0",
      "status": "active",
      "supports_video": true,
      "family": "social_proof",
      "render_mode": "overlay_on_image",
      "layout": {
        "base_family": "image_overlay",
        "overlay_package": "adaptive_scrim",
        "copy_system": "logo_headline_product_cta_quote",
        "motion_system": "subtle_image_motion"
      },
      "aspect_ratios": {
        "supported": ["1:1", "4:5", "9:16", "16:9", "1.91:1"],
        "preferred": ["1:1", "4:5", "9:16"]
      },
      "render_order": ["background_media", "scrim", "logo", "headline", "product_meta", "cta", "quote"],
      "background_binding": {
        "slot_binding": {
          "source_priority": ["product.hero_media", "creator.portrait_media", "ugc.media", "product.image"]
        },
        "comment": "Source media fills the entire canvas — image is the ad. The first three are source-Media-derived smart crops; product.image is the catalog stock fallback (direct CatalogProduct.imageUrl) so brands with only manual-upload catalog rows still render."
      },
      "placement_policy": {
        "algorithm": "greedy_priority_with_overlap_budget",
        "subject_overlap_budget_pct": 10,
        "hard_no_overlay_strictness_floor": 0.95,
        "fallback_modes": ["inset_with_brand_color_bands"],
        "element_priority_order": [
          {
            "id": "logo",
            "required": true,
            "region_hint": "top-left",
            "slot_binding": { "source_priority": ["brand.logo"] }
          },
          {
            "id": "headline",
            "required": true,
            "region_hint": "top-band",
            "scale_text_to_fit": true,
            "slot_binding": { "source_priority": ["copy.headline"] }
          },
          {
            "id": "product_meta",
            "required": true,
            "region_hint": "mid-band",
            "scale_text_to_fit": true,
            "slot_binding": {
              "fields": {
                "name":         { "source_priority": ["product.name"] },
                "price":        { "source_priority": ["product.price"] },
                "currency":     { "source_priority": ["product.currency"] },
                "rating":       { "source_priority": ["social_proof.rating_value"] },
                "review_count": { "source_priority": ["social_proof.review_count"] }
              }
            }
          },
          {
            "id": "cta",
            "required": true,
            "region_hint": "bottom-third",
            "slot_binding": { "source_priority": ["cta.text"] }
          },
          {
            "id": "quote",
            "required": false,
            "region_hint": "flex",
            "truncate": "ellipsis",
            "slot_binding": {
              "fields": {
                "text":   { "source_priority": ["social_proof.primary_quote.text"] },
                "author": { "source_priority": ["social_proof.primary_quote.author_name"] }
              }
            }
          }
        ]
      },
      "visibility_rules": {
        "show_brand_logo": true,
        "show_yellow_stars_for_rating": true,
        "drop_quote_if_no_safe_area": true,
        "rights_gate": {
          "applies_to_paths": ["ugc.media", "ugc.media.image", "ugc.media.video", "ugc.caption", "ugc.likes", "ugc.comments"],
          "requires": "ugc.rights_approved",
          "comment": "When background_binding resolves to ugc.media, the rights flag must be true. Otherwise the resolution falls through to the next source_priority entry (product.hero_media → creator.portrait_media → ugc.media)."
        }
      },
      "truncation_rules": {
        "headline_max_lines": 3,
        "product_name_max_lines": 1,
        "quote_max_lines": 4,
        "cta_max_chars": 24
      },
      "motion_policy": {
        "max_concurrent_motion_slots": 1,
        "preferred_hero_video_slot": "background_media",
        "allow_background_video": true,
        "mute_required": true,
        "loop_required": true,
        "autoplay_required": true,
        "text_overlay_requires_scrim": true,
        "animation_style": "subtle"
      },
      "fallback_policy": {
        "if_no_safe_area_for_required": "switch_to_inset_mode_with_brand_color_bands",
        "if_no_quote_safe_area": "drop_quote_block",
        "if_no_overlay_analysis": "skip_template_invalid"
      },
      "style_bindings": {
        "panel_bg":             { "source_priority": ["media.palette_dominant", "brand.primary_color"], "default": "#0B0B0B", "comment": "right-side content panel — leads with the source Media's dominant background color so the panel reads as an extension of the image" },
        "scrim_tint":           { "source_priority": ["media.palette_dominant", "brand.primary_color"], "default": "#000000" },
        "headline_text_color":  { "source_priority": ["media.palette_accent",   "brand.accent_color"],  "default": "auto-from-brightness", "comment": "image-led: pulls vibrant accent from the source media (flame orange, brand color, etc.) rather than brand-curated. Falls back to brightness-based contrast." },
        "body_text_color":      { "default": "auto-from-brightness" },
        "rating_star_color":    { "default": "#FFD400", "comment": "yellow stars per catalog distinctive_features" },
        "cta_button_bg":        { "source_priority": ["media.palette_accent",   "brand.accent_color",   "brand.primary_color"], "default": "#FF6B35" },
        "cta_button_text":      { "default": "auto-from-brightness" },
        "accent_border_color":  { "source_priority": ["media.palette_accent",   "brand.accent_color"],  "default": "#FF6B35", "comment": "left-edge accent on quote card + section header underline" },
        "section_header_color": { "source_priority": ["media.palette_accent",   "brand.accent_color"],  "default": "#FF6B35", "comment": "uppercase section eyebrow color (e.g. 'BUILT FOR HEAT LOVERS')" },
        "inset_band_color":     { "source_priority": ["media.palette_dominant", "brand.primary_color", "brand.accent_color"], "default": "#0B1020", "comment": "fallback inset mode bands" },
        "font_family_headline": { "source_priority": ["brand.font_family"], "default": "system-ui" },
        "font_family_body":     { "source_priority": ["brand.font_family"], "default": "system-ui" }
      },
      "validation": {
        "required_all_of": ["brand.logo", "copy.headline", "product.name", "cta.text"],
        "required_any_of": [
          ["product.hero_media.image", "creator.portrait_media.image", "ugc.media.image", "product.image"]
        ]
      }
    },
    {
      "template_id": "creator_endorsement",
      "version": "1.0.0",
      "status": "active",
      "supports_video": true,
      "family": "social_proof",
      "layout": {
        "base_family": "creator_led",
        "overlay_package": "trust_ribbon",
        "copy_system": "creator_quote_product_cta",
        "motion_system": "creator_primary_motion"
      },
      "aspect_ratios": {
        "supported": ["1:1", "4:5", "9:16", "16:9", "1.91:1"],
        "preferred": ["1:1", "4:5", "9:16"]
      },
      "zones": {
        "creator_zone": {
          "id": "creator_zone",
          "type": "media",
          "required": true,
          "slot_binding": {
            "source_priority": [
              "creator.portrait_media.video",
              "creator.portrait_media.image",
              "ugc.media.video",
              "ugc.media.image"
            ]
          },
          "media_rules": {
