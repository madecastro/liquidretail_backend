            "source_priority": ["copy.headline", "defaults.fallback_headline"]
          }
        },
        "cta": {
          "id": "cta",
          "type": "button",
          "required": true,
          "slot_binding": {
            "text": ["copy.cta_text", "cta.text", "defaults.cta_text"],
            "url": ["cta.url"]
          }
        }
      },
      "render_order": ["brand", "headline", "center_hero", "review_cards", "summary_badge", "cta", "legal"],
      "slot_adapter": {
        "product.hero_media.image": ["product.hero_media.image", "product.image"],
        "product.hero_media.video": ["product.hero_media.video"],
        "social_proof.secondary_quotes": ["social_proof.secondary_quotes", "social_proof.quotes"],
        "social_proof.rating_value": ["social_proof.rating_value", "social_proof.rating"],
        "social_proof.review_count": ["social_proof.review_count"],
        "trust.trusted_by_text": ["trust.trusted_by_text"],
        "copy.headline": ["copy.headline"],
        "copy.cta_text": ["cta.text", "copy.cta_text"]
      },
      "visibility_rules": {
        "show_headline_if_present": true,
        "show_review_cards_min": 2,
        "show_review_cards_max": 5,
        "show_summary_badge_only_if_rating_or_review_count_present": true
      },
      "truncation_rules": {
        "headline_max_lines": 2,
        "review_card_max_lines": 4,
        "review_author_max_chars": 22,
        "cta_max_chars": 24
      },
      "motion_policy": {
        "max_concurrent_motion_slots": 1,
        "preferred_hero_video_slot": "center_hero",
        "allow_background_video": false,
        "mute_required": true,
        "loop_required": true,
        "autoplay_required": true,
        "review_cards_are_static": true,
        "animation_style": "minimal"
      },
      "fallback_policy": {
        "if_no_video_or_image": "replace center_hero with brand color block",
        "if_only_one_quote": "repeat as primary and secondary style variants disabled",
        "if_no_rating_or_review_count": "hide summary badge",
        "if_no_headline": "use brand tagline"
      },
      "style_bindings": {
        "background_color":     { "source_priority": ["brand.primary_color"],   "default": "#0B1020" },
        "card_bg":              { "source_priority": ["brand.secondary_color"], "default": "#FFFFFF" },
        "card_border":          { "default": "#E5E7EB" },
        "card_text":            { "default": "auto-from-brightness" },
        "headline_text_color":  { "default": "auto-from-brightness", "comment": "renders on brand.primary_color background" },
        "rating_star_color":    { "default": "#FFD400" },
        "summary_badge_bg":     { "source_priority": ["brand.accent_color", "brand.primary_color"], "default": "#7A35E8" },
        "summary_badge_text":   { "default": "auto-from-brightness" },
        "cta_button_bg":        { "source_priority": ["brand.accent_color", "brand.primary_color"], "default": "#000000" },
        "cta_button_text":      { "default": "auto-from-brightness" },
        "font_family_headline": { "source_priority": ["brand.font_family"], "default": "system-ui" },
        "font_family_body":     { "source_priority": ["brand.font_family"], "default": "system-ui" }
      },
      "validation": {
        "required_all_of": ["cta.text"],
        "required_any_of": [
          ["product.hero_media.video", "product.hero_media.image"],
          ["social_proof.secondary_quotes", "social_proof.quotes"]
        ]
      }
    },
