{
  "templates": [
    {
      "template_id": "testimonial_spotlight",
      "version": "1.0.0",
      "status": "active",
      "supports_video": true,
      "family": "social_proof",
      "layout": {
        "base_family": "quote_focus",
        "overlay_package": "rating_bar",
        "copy_system": "headline_quote_cta",
        "motion_system": "subtle_product_motion"
      },
      "aspect_ratios": {
        "supported": ["1:1", "4:5", "9:16", "16:9", "1.91:1"],
        "preferred": ["1:1", "4:5", "9:16"]
      },
      "zones": {
        "hero": {
          "id": "hero_quote",
          "type": "text_card",
          "required": true,
          "slot_binding": {
            "source_priority": [
              "social_proof.primary_quote.text",
              "copy.headline"
            ]
          },
          "limits": {
            "max_chars": {
              "1:1": 140,
              "4:5": 160,
              "9:16": 180,
              "16:9": 120,
              "1.91:1": 110
            }
          }
        },
        "support_media": {
          "id": "support_media",
          "type": "media",
          "required": false,
          "slot_binding": {
            "source_priority": [
              "product.hero_media.video",
              "product.hero_media.image",
              "creator.portrait_media.video",
              "creator.portrait_media.image",
              "product.image"
            ],
            "comment": "Source-Media-derived smart crop wins when a post is the entry point (post → product match → smart crop sized for this slot's ratio). Catalog stock (product.image) is the final fallback when no source Media exists — e.g. running on a manual-upload-only catalog row. Crop is the renderer's responsibility (Cloudinary so_/c_crop transforms when the URL is Cloudinary, object-fit: cover otherwise)."
          },
          "media_rules": {
            "accepted_kinds": ["image", "video"],
            "crop_mode": "subject_preserve",
            "poster_required_for_video": true
          }
        },
        "rating_bar": {
          "id": "rating_bar",
          "type": "proof_bar",
          "required": false,
          "slot_binding": {
            "source_priority": [
              "social_proof.rating_value",
              "social_proof.review_count",
              "trust.trusted_by_text"
            ]
          }
        },
        "product_meta": {
          "id": "product_meta",
          "type": "meta_block",
          "required": true,
          "slot_binding": {
            "name": ["product.name"],
            "price": ["product.price"],
            "currency": ["product.currency"],
            "badges": ["product.badges", "social_proof.proof_badges"]
          }
        },
        "cta": {
          "id": "cta",
          "type": "button",
          "required": true,
          "slot_binding": {
            "text": ["cta.text"],
            "url": ["cta.url"]
          }
        }
      },
      "render_order": ["brand", "hero", "support_media", "rating_bar", "product_meta", "cta", "legal"],
      "slot_adapter": {
        "brand.logo":           ["brand.logo"],
        "brand.brand_name":     ["brand.name"],
        "brand.eyebrow":        ["copy.eyebrow", "brand.tagline"],
        "copy.headline":        ["copy.headline", "social_proof.primary_quote.text"],
        "copy.subheadline":     ["copy.subheadline"],
        "copy.cta_text":        ["cta.text"],
        "social_proof.primary_quote.text":        ["social_proof.primary_quote.text"],
        "social_proof.primary_quote.author_name": ["social_proof.primary_quote.author_name", "creator.name"],
        "social_proof.rating_value":              ["social_proof.rating_value"],
        "social_proof.review_count":              ["social_proof.review_count"],
        "trust.trusted_by_text":                  ["trust.trusted_by_text", "social_proof.trusted_by_text"],
        "product.name":                           ["product.name"],
        "product.price":                          ["product.price"],
        "product.badges":                         ["product.badges", "social_proof.proof_badges"],
        "product.hero_media.image":               ["product.hero_media.image", "product.image"],
        "product.hero_media.video":               ["product.hero_media.video"]
      },
      "visibility_rules": {
        "show_brand_logo": true,
        "show_rating_bar_only_if_any_present": true,
        "show_price_only_if_present": true,
        "show_badges_max": 2
      },
      "truncation_rules": {
        "headline_max_lines": 3,
        "subheadline_max_lines": 2,
        "quote_max_lines": 4,
        "cta_max_chars": 24,
        "product_name_max_lines": 2
      },
      "motion_policy": {
        "max_concurrent_motion_slots": 1,
        "preferred_hero_video_slot": "support_media",
        "allow_background_video": true,
        "mute_required": true,
        "loop_required": true,
        "autoplay_required": true,
        "text_overlay_requires_scrim": true,
        "animation_style": "subtle"
      },
      "fallback_policy": {
        "if_no_quote": "use copy.headline as hero card",
        "if_no_support_media": "render static gradient panel",
        "if_no_rating_data": "hide rating bar",
        "if_no_price": "hide price",
        "if_video_missing_poster": "generate from first frame or fall back to image"
      },
      "style_bindings": {
        "card_bg":              { "source_priority": ["brand.secondary_color"], "default": "#FFFFFF" },
        "card_border":          { "source_priority": ["brand.primary_color"],   "default": "#E5E7EB" },
        "proof_bar_bg":         { "source_priority": ["brand.primary_color"],   "default": "#0B1020" },
        "proof_bar_text":       { "default": "auto-from-brightness" },
        "headline_text_color":  { "source_priority": ["brand.primary_color"],   "default": "#0B1020" },
        "cta_button_bg":        { "source_priority": ["brand.accent_color", "brand.primary_color"], "default": "#000000" },
        "cta_button_text":      { "default": "auto-from-brightness" },
        "rating_star_color":    { "default": "#FFD400" },
        "font_family_headline": { "source_priority": ["brand.font_family"], "default": "system-ui" },
        "font_family_body":     { "source_priority": ["brand.font_family"], "default": "system-ui" }
      },
      "validation": {
        "required_any_of": [["social_proof.primary_quote.text", "copy.headline"]],
        "required_all_of": ["product.name", "cta.text"]
      }
    },
    {
      "template_id": "ugc_split_screen",
      "version": "1.0.0",
      "status": "active",
      "supports_video": true,
      "family": "social_proof",
      "layout": {
        "base_family": "split_focus",
        "overlay_package": "quote_bubble",
        "copy_system": "creator_quote_cta",
        "motion_system": "primary_panel_motion"
      },
      "aspect_ratios": {
        "supported": ["1:1", "4:5", "9:16", "16:9", "1.91:1"],
        "preferred": ["1:1", "4:5", "9:16"]
      },
      "zones": {
        "left_panel": {
          "id": "ugc_panel",
          "type": "media",
          "required": true,
          "slot_binding": {
            "source_priority": [
              "creator.portrait_media.video",
              "creator.portrait_media.image",
              "ugc.media.video",
              "ugc.media.image"
            ]
          },
          "media_rules": {
            "accepted_kinds": ["image", "video"],
            "crop_mode": "subject_preserve",
            "poster_required_for_video": true
          }
        },
        "right_panel": {
          "id": "product_panel",
          "type": "media",
          "required": true,
          "slot_binding": {
            "source_priority": [
              "product.hero_media.video",
              "product.hero_media.image",
              "product.secondary_media.image"
            ]
          },
          "media_rules": {
            "accepted_kinds": ["image", "video"],
            "crop_mode": "subject_preserve",
            "poster_required_for_video": true
          }
        },
        "quote_bubble": {
          "id": "quote_bubble",
          "type": "text_card",
          "required": true,
          "slot_binding": {
            "source_priority": [
              "social_proof.primary_quote.text",
              "ugc.caption",
              "copy.headline",
              "defaults.fallback_quote"
            ]
          },
          "limits": {
            "max_chars": {
              "1:1": 110,
              "4:5": 130,
              "9:16": 140,
              "16:9": 90,
              "1.91:1": 80
            }
          }
        },
        "engagement_row": {
          "id": "engagement_row",
          "type": "chip_row",
          "required": false,
          "slot_binding": {
            "likes": ["performance.engagement.likes", "ugc.likes"],
            "comments": ["performance.engagement.comments", "ugc.comments"],
            "proof_badges": ["social_proof.proof_badges", "product.badges"]
          }
        },
        "identity_row": {
          "id": "identity_row",
          "type": "identity",
          "required": true,
          "slot_binding": {
            "creator_name": ["creator.name", "ugc.creator_name"],
            "creator_handle": ["creator.handle", "ugc.creator_handle"],
            "platform": ["creator.platform", "ugc.platform"]
          }
        },
        "cta": {
          "id": "cta",
          "type": "button",
          "required": true,
          "slot_binding": {
            "text": ["copy.cta_text", "cta.text", "defaults.cta_text"],
            "url": ["cta.url"]
          }
        }
      },
      "render_order": ["brand", "left_panel", "right_panel", "quote_bubble", "engagement_row", "identity_row", "cta", "legal"],
      "slot_adapter": {
        "creator.name": ["ugc.creator_name", "creator.name"],
        "creator.handle": ["ugc.creator_handle", "creator.handle"],
        "creator.platform": ["ugc.platform", "creator.platform"],
        "creator.portrait_media.image": ["ugc.media.image", "creator.portrait_media.image"],
        "creator.portrait_media.video": ["ugc.media.video", "creator.portrait_media.video"],
        "ugc.caption": ["ugc.caption"],
        "ugc.likes": ["ugc.likes"],
        "ugc.comments": ["ugc.comments"],
        "product.name": ["product.name"],
        "product.hero_media.image": ["product.hero_media.image", "product.image"],
        "product.hero_media.video": ["product.hero_media.video"],
        "social_proof.primary_quote.text": [
          "social_proof.primary_quote.text",
          "social_proof.quotes.0.text",
          "ugc.caption"
        ],
        "social_proof.proof_badges": ["social_proof.proof_badges", "product.badges"],
        "copy.cta_text": ["cta.text", "copy.cta_text"]
      },
      "visibility_rules": {
        "show_creator_handle": true,
        "show_platform_badge": true,
        "show_engagement_row_only_if_any_present": true,
        "show_rights_status_only_if_post_type_is_ugc": true
      },
      "truncation_rules": {
        "quote_max_lines": 4,
        "creator_name_max_chars": 28,
        "creator_handle_max_chars": 24,
        "cta_max_chars": 24
      },
      "motion_policy": {
        "max_concurrent_motion_slots": 1,
        "preferred_hero_video_slot": "left_panel",
        "allow_background_video": false,
        "mute_required": true,
        "loop_required": true,
        "autoplay_required": true,
        "if_both_panels_are_video": "autoplay left_panel only, freeze right_panel to poster",
        "text_overlay_requires_scrim": true,
        "animation_style": "dynamic"
      },
      "fallback_policy": {
        "if_no_creator_media": "use product.hero_media in left_panel",
        "if_no_product_media": "use creator media full bleed",
        "if_no_quote": "use ugc.caption",
        "if_no_engagement_data": "hide engagement row",
        "if_no_creator_handle": "show creator name only"
      },
      "style_bindings": {
        "panel_divider_color":  { "source_priority": ["brand.accent_color", "brand.primary_color"], "default": "#FFFFFF" },
        "quote_bubble_bg":      { "source_priority": ["brand.secondary_color"], "default": "#F3F4F6" },
        "quote_bubble_text":    { "default": "auto-from-brightness" },
        "headline_text_color":  { "source_priority": ["brand.primary_color"],   "default": "#0B1020" },
        "cta_button_bg":        { "source_priority": ["brand.accent_color", "brand.primary_color"], "default": "#000000" },
        "cta_button_text":      { "default": "auto-from-brightness" },
        "engagement_chip_bg":   { "default": "rgba(0,0,0,0.55)" },
        "engagement_chip_text": { "default": "#FFFFFF" },
        "creator_handle_color": { "source_priority": ["brand.accent_color"], "default": "#7A35E8" },
        "font_family_headline": { "source_priority": ["brand.font_family"], "default": "system-ui" },
        "font_family_body":     { "source_priority": ["brand.font_family"], "default": "system-ui" }
      },
      "validation": {
        "required_all_of": ["product.name", "cta.text"],
        "required_any_of": [
          ["creator.portrait_media.video", "creator.portrait_media.image", "ugc.media.video", "ugc.media.image"],
          ["product.hero_media.video", "product.hero_media.image"],
          ["social_proof.primary_quote.text", "ugc.caption", "copy.headline"]
        ]
      }
    },
    {
      "template_id": "review_collage",
      "version": "1.0.0",
      "status": "active",
      "supports_video": true,
      "family": "social_proof",
      "layout": {
        "base_family": "grid_showcase",
        "overlay_package": "review_cards",
        "copy_system": "headline_summary_cta",
        "motion_system": "hero_only_motion"
      },
      "aspect_ratios": {
        "supported": ["1:1", "4:5", "9:16", "16:9", "1.91:1"],
        "preferred": ["1:1", "4:5"]
      },
      "zones": {
        "center_hero": {
          "id": "center_hero",
          "type": "media",
          "required": true,
          "slot_binding": {
            "source_priority": [
              "product.hero_media.video",
              "product.hero_media.image",
              "product.secondary_media.image"
            ]
          },
          "media_rules": {
            "accepted_kinds": ["image", "video"],
