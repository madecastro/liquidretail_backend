        "preferred_hero_video_slot": "creator_zone",
        "allow_background_video": false,
        "mute_required": true,
        "loop_required": true,
        "autoplay_required": true,
        "if_creator_and_product_are_both_video": "autoplay creator_zone only, render product_zone as poster or tap-to-play secondary",
        "text_overlay_requires_scrim": true,
        "animation_style": "creator_led"
      },
      "fallback_policy": {
        "if_no_creator_media": "use product media as primary and convert template to simplified endorsement mode",
        "if_no_product_media": "render product name and badges only",
        "if_no_quote": "use copy.headline",
        "if_no_social_ribbon_data": "hide ribbon"
      },
      "style_bindings": {
        "trust_ribbon_bg":      { "source_priority": ["brand.accent_color", "brand.primary_color"], "default": "#7A35E8" },
        "trust_ribbon_text":    { "default": "auto-from-brightness" },
        "creator_card_bg":      { "source_priority": ["brand.secondary_color"], "default": "#FFFFFF" },
        "creator_card_text":    { "default": "auto-from-brightness" },
        "creator_name_color":   { "source_priority": ["brand.primary_color"],   "default": "#0B1020" },
        "creator_handle_color": { "source_priority": ["brand.accent_color"],    "default": "#7A35E8" },
        "headline_text_color":  { "source_priority": ["brand.primary_color"],   "default": "#0B1020" },
        "rating_star_color":    { "default": "#FFD400" },
        "cta_button_bg":        { "source_priority": ["brand.accent_color", "brand.primary_color"], "default": "#000000" },
        "cta_button_text":      { "default": "auto-from-brightness" },
        "font_family_headline": { "source_priority": ["brand.font_family"], "default": "system-ui" },
        "font_family_body":     { "source_priority": ["brand.font_family"], "default": "system-ui" }
      },
      "validation": {
        "required_all_of": ["cta.text"],
        "required_any_of": [
          ["creator.portrait_media.video", "creator.portrait_media.image", "ugc.media.video", "ugc.media.image"],
          ["product.hero_media.video", "product.hero_media.image"],
          ["social_proof.primary_quote.text", "social_proof.quotes.0.text", "copy.headline"]
        ]
      }
    }
  ]
}
