            "proof_badges": ["social_proof.proof_badges", "product.badges"],
            "trusted_by_text": ["trust.trusted_by_text"]
          }
        },
        "cta": {
          "id": "cta",
          "type": "button",
          "required": true,
          "slot_binding": {
            "text": ["copy.cta_text", "cta.text", "defaults.cta_text"],
            "url": ["cta.url"]
          }
        }
      },
      "render_order": ["brand", "creator_zone", "endorsement_quote", "product_zone", "social_ribbon", "cta", "legal"],
      "slot_adapter": {
        "creator.name": ["ugc.creator_name", "creator.name"],
        "creator.handle": ["ugc.creator_handle", "creator.handle"],
        "creator.portrait_media.image": ["ugc.media.image", "creator.portrait_media.image"],
        "creator.portrait_media.video": ["ugc.media.video", "creator.portrait_media.video"],
        "product.hero_media.image": ["product.hero_media.image", "product.image"],
        "product.hero_media.video": ["product.hero_media.video"],
        "social_proof.primary_quote.text": [
          "social_proof.primary_quote.text",
          "social_proof.quotes.0.text",
          "copy.headline"
        ],
        "social_proof.proof_badges": ["social_proof.proof_badges", "product.badges"],
        "trust.trusted_by_text": ["trust.trusted_by_text"],
        "copy.cta_text": ["cta.text", "copy.cta_text"]
      },
      "visibility_rules": {
        "show_creator_handle": true,
        "show_social_ribbon_only_if_any_present": true,
        "show_brand_logo": true,
        "show_product_zone_as_inset_on_mobile_if_creator_video_present": true
      },
      "truncation_rules": {
        "quote_max_lines": 4,
        "creator_name_max_chars": 26,
        "creator_handle_max_chars": 24,
        "cta_max_chars": 24
      },
      "motion_policy": {
